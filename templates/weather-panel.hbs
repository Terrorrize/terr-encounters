<form class="weather-panel weather-panel-compact">
  <section class="weather-panel-toolbar">
    <button type="button" data-action="main-day-action" class="weather-main-button">{{mainButtonLabel}}</button>
    <button type="button" data-action="reset-current-set" class="weather-reroll-button" title="Start over">↻</button>
  </section>

  <div class="weather-panel-body">
    <section class="weather-day-card">
      <div class="weather-day-card-top">
        <div class="weather-day-badge">{{displayDayCounter}}</div>
      </div>

      {{#if hasStarted}}
      <div class="weather-state-line">{{displayTemperatureState}} / {{displayWeatherLabel}}</div>
      <div class="weather-temp-line">{{displayTemperatureValue}}</div>
      <div class="weather-feel-line">{{displayTemperatureType}}</div>

      <div class="weather-ground-block">
        <div class="weather-ground-label">Ground</div>
        <div class="weather-ground-value">
          {{#each groundBits}}
          <div class="weather-ground-bit">{{this}}</div>
          {{/each}}
        </div>
      </div>
      {{else}}
      <div class="weather-empty-block">Press “How's My Day Going?” to start the current set.</div>
      {{/if}}
    </section>

    <details class="weather-controls-dropdown">
      <summary class="weather-controls-summary">Controls</summary>

      <div class="weather-controls-body">
        <div class="weather-inline-grid weather-inline-grid-3">
          <div class="weather-field">
            <label for="{{moduleId}}-biome">Biome</label>
            <select id="{{moduleId}}-biome" name="biome">
              {{#each biomeChoices}}
              <option value="{{this.value}}" {{#if (eq ../controls.biome this.value)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>

          <div class="weather-field">
            <label for="{{moduleId}}-season">Season</label>
            <select id="{{moduleId}}-season" name="season">
              {{#each seasonChoices}}
              <option value="{{this.value}}" {{#if (eq ../controls.season this.value)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>

          <div class="weather-field">
            <label for="{{moduleId}}-phase">Phase</label>
            <select id="{{moduleId}}-phase" name="phase">
              {{#each phaseChoices}}
              <option value="{{this.value}}" {{#if (eq ../controls.phase this.value)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="weather-ruins-inline">
          <label class="checkbox weather-ruins-toggle">
            <input type="checkbox" name="addRuins" {{#if controls.addRuins}}checked{{/if}}>
            Add Ruins
          </label>

          <div class="weather-inline-grid weather-inline-grid-3 weather-ruins-controls {{#unless controls.addRuins}}is-disabled{{/unless}}">
            <div class="weather-field">
              <label for="{{moduleId}}-ruin-frequency">Ruin Freq</label>
              <select id="{{moduleId}}-ruin-frequency" name="ruinFrequency" {{#unless controls.addRuins}}disabled{{/unless}}>
                {{#each ruinFrequencyChoices}}
                <option value="{{this.value}}" {{#if (eq ../controls.ruinFrequency this.value)}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
              </select>
            </div>

            <div class="weather-field">
              <label for="{{moduleId}}-ruin-style-mode">Ruin Style</label>
              <select id="{{moduleId}}-ruin-style-mode" name="ruinStyleMode" {{#unless controls.addRuins}}disabled{{/unless}}>
                {{#each ruinStyleModeChoices}}
                <option value="{{this.value}}" {{#if (eq ../controls.ruinStyleMode this.value)}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
              </select>
            </div>

            <div class="weather-field">
              <label for="{{moduleId}}-manual-ruin-family">Ruin Family</label>
              <select id="{{moduleId}}-manual-ruin-family" name="manualRuinFamily" {{#unless controls.addRuins}}disabled{{/unless}}>
                <option value=""></option>
                {{#each manualRuinFamilyChoices}}
                <option value="{{this.value}}" {{#if (eq ../controls.manualRuinFamily this.value)}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
              </select>
            </div>
          </div>
        </div>
      </div>
    </details>
  </div>
</form>