<form class="weather-panel">
  <section class="weather-panel-toolbar">
    <button type="button" data-action="main-day-action" class="weather-main-button">{{mainButtonLabel}}</button>
    <button type="button" data-action="reset-current-set" class="weather-reroll-button" title="Start over">↻</button>
  </section>

  <div class="weather-panel-body">
    <details class="weather-block weather-current-day" open>
      <summary class="weather-block-summary">
        <span class="weather-block-title">Current Day</span>
      </summary>

      <div class="weather-block-body">
        <div class="weather-summary-grid">
          <div class="weather-summary-item">
            <label>Day</label>
            <div>{{#if hasStarted}}{{dayLabel}}{{else}}Not started{{/if}}</div>
          </div>

          <div class="weather-summary-item">
            <label>Biome</label>
            <div>{{biome}}</div>
          </div>

          <div class="weather-summary-item">
            <label>Season</label>
            <div>{{season}}</div>
          </div>

          <div class="weather-summary-item">
            <label>Phase</label>
            <div>{{phase}}</div>
          </div>

          <div class="weather-summary-item">
            <label>Ground State</label>
            <div>{{#if hasStarted}}{{groundState}}{{else}}—{{/if}}</div>
          </div>

          <div class="weather-summary-item">
            <label>Temperature</label>
            <div>
              {{#if hasStarted}}
                {{temperatureState}} ({{temperatureDaysRemaining}} days remaining)
              {{else}}
                —
              {{/if}}
            </div>
          </div>

          <div class="weather-summary-item">
            <label>Weather</label>
            <div>
              {{#if hasStarted}}
                {{weatherEvent}} ({{weatherDaysRemaining}} days remaining)
              {{else}}
                —
              {{/if}}
            </div>
          </div>

          {{#if hasRuinsApplied}}
          <div class="weather-summary-item">
            <label>Ruins</label>
            <div>{{ruinModifier}} — {{ruinFamily}}</div>
          </div>
          {{/if}}
        </div>
      </div>
    </details>

    <details class="weather-block weather-controls" open>
      <summary class="weather-block-summary">
        <span class="weather-block-title">Controls</span>
      </summary>

      <div class="weather-block-body">
        <div class="weather-field">
          <label for="{{moduleId}}-biome">Biome</label>
          <select id="{{moduleId}}-biome" name="biome">
            {{#each biomeChoices}}
            <option value="{{this.value}}" {{#if (eq ../controls.biome this.value)}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>

        <div class="weather-inline-grid weather-inline-grid-2">
          <div class="weather-field">
            <label for="{{moduleId}}-season">Season</label>
            <select id="{{moduleId}}-season" name="season">
              {{#each seasonChoices}}
              <option value="{{this.value}}" {{#if (eq ../controls.season this.value)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>

          <div class="weather-field">
            <label for="{{moduleId}}-phase">Phase</label>
            <select id="{{moduleId}}-phase" name="phase">
              {{#each phaseChoices}}
              <option value="{{this.value}}" {{#if (eq ../controls.phase this.value)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>
        </div>
      </div>
    </details>

    <details class="weather-block weather-ruins">
      <summary class="weather-block-summary">
        <span class="weather-block-title">Ruins</span>
      </summary>

      <div class="weather-block-body">
        <div class="weather-field weather-checkbox-row">
          <label class="checkbox">
            <input type="checkbox" name="addRuins" {{#if controls.addRuins}}checked{{/if}}>
            Add Ruins
          </label>
        </div>

        <div class="weather-inline-grid weather-inline-grid-2 weather-ruins-controls {{#unless controls.addRuins}}is-disabled{{/unless}}">
          <div class="weather-field">
            <label for="{{moduleId}}-ruin-frequency">Ruin Frequency</label>
            <select id="{{moduleId}}-ruin-frequency" name="ruinFrequency" {{#unless controls.addRuins}}disabled{{/unless}}>
              {{#each ruinFrequencyChoices}}
              <option value="{{this.value}}" {{#if (eq ../controls.ruinFrequency this.value)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>

          <div class="weather-field">
            <label for="{{moduleId}}-ruin-style-mode">Ruin Style Mode</label>
            <select id="{{moduleId}}-ruin-style-mode" name="ruinStyleMode" {{#unless controls.addRuins}}disabled{{/unless}}>
              {{#each ruinStyleModeChoices}}
              <option value="{{this.value}}" {{#if (eq ../controls.ruinStyleMode this.value)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        {{#if showManualRuinFamily}}
        <div class="weather-field weather-ruin-family">
          <label for="{{moduleId}}-manual-ruin-family">Ruin Family</label>
          <select id="{{moduleId}}-manual-ruin-family" name="manualRuinFamily" {{#unless controls.addRuins}}disabled{{/unless}}>
            <option value=""></option>
            {{#each manualRuinFamilyChoices}}
            <option value="{{this.value}}" {{#if (eq ../controls.manualRuinFamily this.value)}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>
        {{/if}}
      </div>
    </details>

    <details class="weather-block weather-output" open>
      <summary class="weather-block-summary">
        <span class="weather-block-title">Narrative Output</span>
      </summary>

      <div class="weather-block-body">
        {{#if hasStarted}}
        <div class="weather-output-list">
          {{#each orderedOutput}}
          <div class="weather-output-line weather-output-line-{{this.key}}">
            <label>{{this.label}}</label>
            <p>{{this.text}}</p>
          </div>
          {{/each}}
        </div>
        {{else}}
        <div class="weather-output-empty">Press “How's My Day Going?” to start the current set.</div>
        {{/if}}
      </div>
    </details>
  </div>
</form>